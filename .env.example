# Which backend runs the code. The HTTP API is identical either way.
SANDBOX_PROVIDER=gvisor

# Shared bearer token the backend/agent must send (Authorization: Bearer <token>).
# Leave empty to disable auth — DEV ONLY.
LLM_SANDBOX_TOKEN=change-me

# Runtime image untrusted code executes in (build from sandbox.Dockerfile).
SANDBOX_IMAGE=llm-sandbox-runtime:latest

# gVisor in prod. Set to "runc" on a machine WITHOUT gVisor to test plumbing locally
# (runc is NOT a security boundary — never use it for untrusted code in prod).
SANDBOX_DOCKER_RUNTIME=runsc

# Hard cap on any single stdout/stderr/file payload returned to the caller.
SANDBOX_MAX_OUTPUT_BYTES=1000000
